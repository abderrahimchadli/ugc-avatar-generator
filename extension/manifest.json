{
  "manifest_version": 3,
  "name": "UGC Avatar Studio Bridge",
  "description": "Bridge prompts and generated images between Avatar Studio, Google Flow, ChatGPT, and Higgsfield packages.",
  "version": "0.2.2",
  "permissions": ["storage", "tabs", "activeTab", "scripting", "clipboardWrite"],
  "host_permissions": [
    "https://labs.google/*",
    "https://chatgpt.com/*",
    "https://*.vercel.app/*",
    "http://localhost:5173/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://labs.google/*",
        "https://chatgpt.com/*",
        "https://*.vercel.app/*",
        "http://localhost:5173/*"
      ],
      "js": ["bridgeCore.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "UGC Bridge",
    "default_popup": "popup.html"
  }
}
